# Encryption key (at-rest secret encryption) and backup data dir — never commit.
# NOTE: do not use a bare "backups/" — it would also ignore the source package
# internal/api/backups. Backup *.db files are already covered by *.db above.
secret.key
backend/secret.key
/backend/backups/
backend/tracker.db.bak
backend/backend_debug.log
backend/test-results/
backend/server
backend/ttgo-linux
backend/ttgo
backend/uploads/
backend/server.log
*.db
*.db-shm
*.db-wal

# OS
.DS_Store
Thumbs.db

# Env
backend/.env
.env
.env.local
.env.*.local

# IDE
.idea/

# Debug artifacts
frontend/debug_*
frontend/*.log
frontend/multi_select_verification.png

# Tool internals
.superpowers/
.specify/
.worktrees/

# Claude Code local state & local-only commands (keep launch.json + skills/ tracked)
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/commands/speckit.*.md

# Internal docs & specs — kept locally, not shared in the public repo.
# Exception: docs/images/ holds the screenshots embedded in README.md, so it
# must stay tracked and public. (Use /docs/* + a negation, not /docs/, because
# a child cannot be re-included once its parent directory is fully excluded.)
/docs/*
!/docs/images/
/specs/
